# ─────────────────────────────────────────────────────────────────
# Gmail AI Manager — 环境变量配置示例
# 复制本文件为 .env，并填入真实值后启动服务
# Copy this file to .env and fill in real values before starting
# ─────────────────────────────────────────────────────────────────

# ── Telegram Bot ──────────────────────────────────────────────────
# 获取方式 / How to get:
#   1. 在 Telegram 搜索 @BotFather，发送 /newbot
#   2. 按提示输入 Bot 名称和用户名，BotFather 会返回 Token
#   Search @BotFather on Telegram, send /newbot and follow the steps
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 你的 Telegram Chat ID（个人 / 群组均可）
# How to get your Chat ID:
#   方法1：搜索 @userinfobot，发送任意消息，它会回复你的 Chat ID
#   方法2：启动 Bot 后向 Bot 发一条消息，访问:
#           https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#           在返回 JSON 的 message.chat.id 字段中找到你的 ID
TELEGRAM_CHAT_ID=your_chat_id_here

# Telegram callback 签名密钥（用于 inline button callback_data 防伪造/过期校验）
# 建议长度：32+ 随机字符；修改后需重启后端
TELEGRAM_CALLBACK_SECRET=change-me

# ── Auth (JWT) ───────────────────────────────────────────────────
# 管理员账号：服务启动时若不存在 admin 会自动创建
ADMIN_USER=admin@local.com
ADMIN_PASSWORD=change-me

# JWT 签名密钥（生产环境务必修改）
JWT_SECRET=change-me-in-production

# JWT 有效期（分钟）
JWT_EXPIRE_MINUTES=60

# ── Database & Redis ─────────────────────────────────────────────
# PostgreSQL 连接字符串
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/xiaoxing

# Supabase Postgres（可选）
# 方式1：直接填写 Supabase 提供的连接串到 POSTGRES_DSN
# 方式2：填写到 SUPABASE_DB_DSN（优先级高于 POSTGRES_DSN）
SUPABASE_DB_DSN=

# 数据库连接池（Supabase 推荐使用 pooler DSN 并适当调小连接数）
DB_POOL_MINCONN=1
DB_POOL_MAXCONN=10

# 强制 sslmode（Supabase 通常需要 require；留空则对 supabase host 自动 require）
DB_SSLMODE=

# 是否允许在首次初始化时清理旧表（默认 false，避免误删）
DB_ALLOW_LEGACY_DROP=false

# Redis（可选，不可达时会自动降级：无缓存/无去重/无队列）
REDIS_URL=redis://localhost:6380

# ── Gmail 轮询配置 / Gmail Polling ───────────────────────────────
# 获取方式 / How to get credentials.json:
#   1. 打开 Google Cloud Console: https://console.cloud.google.com/
#   2. 新建项目（或选择已有项目）
#   3. 启用 Gmail API：API 和服务 → 库 → 搜索 "Gmail API" → 启用
#   4. 创建 OAuth 凭据：API 和服务 → 凭据 → 创建凭据 → OAuth 客户端 ID
#      - 应用类型选 "桌面应用"（Desktop app）
#   5. 下载 JSON 文件，重命名为 credentials.json 放到项目根目录
#   6. 启动服务后访问 http://127.0.0.1:8000/gmail/auth 完成授权
#      授权成功后会自动生成 token.json（请勿提交到 git）
#
#   1. Go to https://console.cloud.google.com/
#   2. Create or select a project
#   3. Enable Gmail API: APIs & Services → Library → search "Gmail API"
#   4. Create OAuth credentials: APIs & Services → Credentials
#      → Create Credentials → OAuth client ID → Desktop app
#   5. Download the JSON, rename it credentials.json, place in project root
#   6. Visit http://127.0.0.1:8000/gmail/auth to complete authorization

# 轮询间隔（秒）/ Poll interval in seconds
GMAIL_POLL_INTERVAL=300

# Gmail 搜索语法 / Gmail search query
# category:primary 只拉取主收件箱（排除促销/社交等）
GMAIL_POLL_QUERY=is:unread in:inbox category:primary

# 每次最多处理邮件数 / Max emails to process per poll
GMAIL_POLL_MAX=20

# 处理后是否标记为已读 / Mark as read after processing
GMAIL_MARK_READ=true

# ── 优先级过滤 / Priority Filter ─────────────────────────────────
# 只通知指定优先级的邮件，逗号分隔；留空则全部通知
# Only notify emails of these priorities (comma-separated); leave empty to notify all
# 可选值 / Options: high, medium, low
NOTIFY_MIN_PRIORITY=high,medium

# ── LLM 后端配置 / LLM Backend ───────────────────────────────────
#
# 本项目支持两种 LLM 后端，通过 LLM_BACKEND 切换：
# This project supports two LLM backends, switched via LLM_BACKEND:
#
#  local  — 使用本地运行的 llama-server（OpenAI 兼容接口）【默认】
#           Use a locally running llama-server (OpenAI-compatible API) [default]
#           配套启动：.bat/Launch.bat 会自动启动 llama-server
#           Launch.bat will start llama-server automatically
#
#  openai — 直接调用 OpenAI API（无需本地 GPU）
#           Call the OpenAI API directly (no local GPU required)
#           需要设置 OPENAI_API_KEY
#           Requires OPENAI_API_KEY to be set

LLM_BACKEND=local

# LLM API 端点 / LLM API endpoint
#  local  默认: http://127.0.0.1:8001/v1/chat/completions
#  openai 默认: https://api.openai.com/v1/chat/completions
LLM_API_URL=http://127.0.0.1:8001/v1/chat/completions

# 模型名称 / Model name
#  local  示例: local-model（llama-server 加载的模型文件名）
#  openai 示例: gpt-4o-mini、gpt-4o
LLM_MODEL=local-model

# OpenAI API Key（仅 LLM_BACKEND=openai 时需要填写）
# Only required when LLM_BACKEND=openai
# 获取方式: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Router LLM（可选）────────────────────────────────────────────
# 用于工具路由意图识别；留空则复用主 LLM
ROUTER_API_URL=http://127.0.0.1:8002/v1/chat/completions
ROUTER_MODEL=local-router

# ── 前端地址 / Frontend URL ───────────────────────────────────────
# 用于 OAuth 回调重定向和 CORS 允许来源
# Used for OAuth callback redirect and CORS allowed origin
#
# 开发时使用 Vite 默认地址 / Development (Vite dev server):
FRONTEND_URL=http://localhost:5173
# 生产时替换为你的部署地址 / Production: replace with your deployed URL
# FRONTEND_URL=https://your-frontend.example.com

# Web 默认语言（en/zh）
UI_LANG=en

# ── Outgoing Email（草稿/确认发送）───────────────────────────────
# 草稿正文加密密钥：base64(32 bytes)。
# 生成方式示例（Python）：
#   python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
OUTGOING_EMAIL_ENCRYPTION_KEY=

# 草稿有效期（分钟，超时后不再允许确认发送）
OUTGOING_DRAFT_TTL_MINUTES=30
